apiVersion: v1
kind: Pod
metadata:
  name: mypod
  labels:
    app: myapp
    env: devops

spec:
  containers:
    - name: nginx-container
      image: nginx:latest
      ports:
        - name: nginx-port
          containerPort: 80

---
apiVersion: v1
kind: Service
metadata:
  name: ciservice
  labels:
    app: myapp

spec:
  type: ClusterIP
  selector:
    app: myapp
  ports:
    - name: nginxsvc-port
      protocol: TCP
      port: 80
      targetPort: 80